{
  "name": "openroom-web",
  "version": "0.0.0",
  "private": true,
  "description": "openroom.channel — landing page, room viewer, and docs",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check",
    "format": "biome format --write",
    "build:worker": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare preview",
    "deploy:cf": "opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "fumadocs-core": "16.7.11",
    "fumadocs-mdx": "14.2.11",
    "fumadocs-ui": "16.7.11",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "openroom-sdk": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@opennextjs/cloudflare": "^1.19.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "wrangler": "^4.81.1"
  }
}